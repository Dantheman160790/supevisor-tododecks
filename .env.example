# ─────────────────────────────────────────────────────
# TODO DECKS SUPERVISOR — Variables de entorno
# En Railway: Settings → Variables → Add Variable
# ─────────────────────────────────────────────────────

# ODOO (mismas credenciales que el plan financiero)
ODOO_URL=https://todo-decks.odoo.com
ODOO_DB=todo-decks
ODOO_USER=tu_email@tododecks.com
ODOO_PASS=tu_contraseña_odoo

# SLACK WEBHOOKS
# Canal principal (resúmenes + cierres)
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Canal de alertas urgentes (puede ser el mismo o diferente)
# Si lo dejas vacío, usa el mismo SLACK_WEBHOOK
SLACK_WEBHOOK_ALERTS=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Puerto (Railway lo asigna automáticamente)
PORT=4000
